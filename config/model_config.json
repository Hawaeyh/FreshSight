{
  "model_name": "mobilenet_v2",
  "pretrained_weights": "IMAGENET1K_V1",
  "freeze_backbone": true,
  "classes": ["Fresh", "Unripe", "Rotten"],
  "image_size": 224,
  "resize_size": 256,
  "batch_size": 32,
  "num_epochs": 20,
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "dropout": 0.3,
  "use_class_weights": true,
  "oversampling": false,
  "early_stopping_patience": 5,
  "early_stopping_min_delta": 0.001,
  "scheduler_factor": 0.5,
  "scheduler_patience": 2,
  "mixed_precision": true,
  "pin_memory": true,
  "num_workers": 2,
  "seed": 42,
  "device": "cuda",
  "train_augmentation": {
    "random_resized_crop_scale": [0.85, 1.0],
    "random_resized_crop_ratio": [0.9, 1.1],
    "horizontal_flip_probability": 0.5,
    "rotation_degrees": 8,
    "brightness": 0.08,
    "contrast": 0.08,
    "saturation": 0.0,
    "hue": 0.0
  },
  "manifest_path": "evaluation/outputs/dataset_manifest.csv",
  "best_checkpoint_path": "ai/checkpoints/mobilenetv2_cleaned_baseline/best_model.pth",
  "last_checkpoint_path": "ai/checkpoints/mobilenetv2_cleaned_baseline/last_model.pth",
  "training_history_json": "outputs/training/mobilenetv2_cleaned_baseline/training_history.json",
  "training_history_csv": "outputs/training/mobilenetv2_cleaned_baseline/training_history.csv",
  "training_config_output": "outputs/training/mobilenetv2_cleaned_baseline/training_config.json",
  "high_confidence_threshold": 0.85,
  "low_confidence_threshold": 0.55
}
